# Supabase PostgreSQL — use the pooler connection string from Supabase dashboard
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-ap-southeast-2.pooler.supabase.com:6543/postgres
DATABASE_URL=your_supabase_pooler_connection_string

# Resend API
RESEND_API_KEY=your_resend_api_key

# Resend sender address
# During testing: leave blank (uses onboarding@resend.dev — limited to 1 email/day)
# For production: verify plumajoinery.com in Resend dashboard, then set:
RESEND_FROM_ADDRESS=Pluma Joinery Studio <hello@plumajoinery.com>

# Notification email (where new lead emails are delivered)
EMAIL_ADDRESS=plumakitchenscarpentry@gmail.com

# Public URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://www.plumajoinery.com
